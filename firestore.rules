
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    function isUnchanged(key) {
      return request.resource.data[key] == resource.data[key];
    }

    match /waitlist_entries/{waitlistEntryId} {
      allow create: if true;
      allow get, list, update, delete: if false;
    }

    match /contact_form_entries/{contactFormEntryId} {
      allow create: if true;
      allow get, list, update, delete: if false;
    }

    match /blog_posts/{blogPostId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.authorId == request.auth.uid && isUnchanged('authorId');
      allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }

    match /authors/{authorId} {
      allow get, list: if true;
      allow create: if isOwner(authorId);
      allow update, delete: if isExistingOwner(authorId);
    }

    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if isExistingOwner(userId);

      match /google_api_keys/{googleApiKeyId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && isUnchanged('userId');
        allow delete: if isExistingOwner(userId);
      }
    }
  }
}
